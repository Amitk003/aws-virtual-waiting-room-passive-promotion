{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Virtual Waiting Room table for Zero-Write Passive Promotion architecture using Time-Density Watermarking",
  "Resources": {
    "VirtualWaitingRoomTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": "VirtualWaitingRoom",
        "AttributeDefinitions": [
          {
            "AttributeName": "PK",
            "AttributeType": "S"
          },
          {
            "AttributeName": "SK",
            "AttributeType": "S"
          }
        ],
        "KeySchema": [
          {
            "AttributeName": "PK",
            "KeyType": "HASH"
          },
          {
            "AttributeName": "SK",
            "KeyType": "RANGE"
          }
        ],
        "BillingMode": "PROVISIONED",
        "ProvisionedThroughput": {
          "ReadCapacityUnits": "5000",
          "WriteCapacityUnits": "1000000"
        },
        "StreamSpecification": {
          "StreamViewType": "NEW_AND_OLD_IMAGES"
        },
        "TimeToLiveSpecification": {
          "AttributeName": "ExpiresAt",
          "Enabled": true
        },
        "Tags": [
          {
            "Key": "Project",
            "Value": "VirtualWaitingRoom"
          }
        ]
      }
    }
  }
}
